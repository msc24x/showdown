FROM ubuntu

ENV COMPILERS_PATH ""

# C & C++
RUN apt-get update && \
    apt-get install -y build-essential

RUN apt-get -y install curl sudo zlib1g-dev

# GOLANG
ENV X_GOLANG_VERSION 1.20.7
RUN curl -OLf https://golang.org/dl/go$X_GOLANG_VERSION.linux-amd64.tar.gz && \
    tar -C /usr/local -xzf go$X_GOLANG_VERSION.linux-amd64.tar.gz

ENV COMPILERS_PATH=$COMPILERS_PATH:/usr/local/go/bin

# Python
ENV X_PYTHON_VERSION 3.12.0
RUN curl -Of https://www.python.org/ftp/python/${X_PYTHON_VERSION}/Python-${X_PYTHON_VERSION}.tgz && \
    tar -xvzf Python-${X_PYTHON_VERSION}.tgz
RUN cd Python-${X_PYTHON_VERSION} && \
    ./configure \
        --prefix=/opt/python/${X_PYTHON_VERSION} \
        --enable-shared \
        --enable-optimizations \
        --enable-ipv6 \
        LDFLAGS=-Wl,-rpath=/opt/python/${X_PYTHON_VERSION}/lib,--disable-new-dtags
RUN cd Python-${X_PYTHON_VERSION} && \
    make && \
    sudo make install

ENV COMPILERS_PATH=$COMPILERS_PATH:/opt/python/$X_PYTHON_VERSION/bin/

# NODE
ENV X_NODE_VERSION 20.x
RUN curl -fsSL https://deb.nodesource.com/setup_$X_NODE_VERSION | sudo bash - && \
    sudo apt-get install -y nodejs
RUN npm install -g typescript && \
    npm install -g ts-node


# ISOLATE
RUN apt-get -y install git libcap-dev libsystemd-dev pkg-config

RUN git clone --depth 1 --branch v1.10.1 https://github.com/ioi/isolate && \
    cd isolate && \
    sudo make isolate && \
    sudo make install

ENV ISOLATE_PATH=${pwd}/isolate/isolate

RUN rm -rf /tmp/*