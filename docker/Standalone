FROM golang:1.20 AS build

ENV APP_DIR /showdown

WORKDIR $APP_DIR
COPY . .

RUN go build -o ./server ./cmd/showdown

FROM compilers-base AS server

ENV APP_DIR /showdown
WORKDIR $APP_DIR

RUN adduser showdown \
    && echo "showdown ALL=(ALL) NOPASSWD: ${APP_DIR}/server" >> /etc/sudoers

COPY --from=build $APP_DIR/server server

RUN chown -R showdown:1000 $APP_DIR

RUN mkdir -p tools/isolate/bin && cp $ISOLATE_PATH tools/isolate/bin/isolate
RUN mkdir -p tmp
RUN mkdir -p env

RUN echo "showdown ALL=(ALL) NOPASSWD: ${APP_DIR}/tools/isolate/bin/isolate" >> /etc/sudoers

ENV PATH=$PATH:$COMPILERS_PATH

USER showdown

CMD ["sudo", "./server", "-start", "-config", "./env/.config"]